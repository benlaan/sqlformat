<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="12.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <OutputDirectory>$(SolutionDir)\Generated</OutputDirectory>
        <AssemblyInfoFile Condition=" '$(AssemblyInfoFile)'=='' ">$(OutputDirectory)\AssemblyInfo.cs</AssemblyInfoFile>

        <BuildYear>$([System.DateTime]::Now.Year.ToString("0000"))</BuildYear>
        <Date>$([System.DateTime]::Now.ToString("u"))</Date>

        <!-- Git related properties: these are set by targets below -->
        <CommitId></CommitId>
        <BranchName></BranchName>
    </PropertyGroup>

    <Target Name="GetCommitId" Condition="'$(CommitId)' == ''">
        <Exec Command="git rev-parse --short HEAD" ConsoleToMsBuild="True" StandardOutputImportance="Low">
            <Output TaskParameter="ConsoleOutput" PropertyName="CommitId" />
        </Exec>
        <Message Text="Git Commit: $(CommitId)" />
    </Target>

    <Target Name="GetRevisionNumber" Condition="'$(Revision)' == '0'">
        <Exec Command="git rev-list --count --all" ConsoleToMsBuild="True" StandardOutputImportance="Low">
            <Output TaskParameter="ConsoleOutput" PropertyName="Revision" />
        </Exec>
        <Message Text="Git Revision Number: $(Revision)" Importance="High" />
    </Target>

    <Target Name="GetBranchName" Condition="'$(BranchName)' == ''">
        <Exec Command="git rev-parse --abbrev-ref HEAD" ConsoleToMsBuild="True" StandardOutputImportance="Low">
            <Output TaskParameter="ConsoleOutput" PropertyName="BranchName" />
        </Exec>
        <Message Text="Git Branch: $(BranchName)" />
    </Target>

    <Target Name="GetRepositoryUrl" Condition="'$(BranchName)' == ''">
        <Exec Command="git config --get remote.origin.url" ConsoleToMsBuild="True" StandardOutputImportance="Low">
            <Output TaskParameter="ConsoleOutput" PropertyName="GitRepositoryUrl" />
        </Exec>
        <Message Text="Git Repository Url: $(GitRepositoryUrl)" />
    </Target>

    <Target Name="GetRepoInfo">
        <CallTarget Condition="Exists('$(SolutionDir).git')" Targets="GetCommitId; GetRevisionNumber; GetBranchName" />
    </Target>

    <Target Name="CalculateRepoInfo" DependsOnTargets="GetRepoInfo">
        <PropertyGroup>
            <RepositoryInfo >+$(CommitId) ($(BranchName))</RepositoryInfo>
            <RepositoryRevisionId>$(CommitId)</RepositoryRevisionId>
            <RepositoryType>git</RepositoryType>
            <RepositoryUrl Condition="'$(GitRepositoryUrl)' != ''">$(GitRepositoryUrl)</RepositoryUrl>

            <!-- Calculated expressions -->
            <FullBuildVersion>$(Major).$(Minor).$(Build).$(Revision)</FullBuildVersion>
            <InformationalVersion>$(FullBuildVersion)$(RepositoryInfo) | Time: $(Date)</InformationalVersion>
        </PropertyGroup>
    </Target>
</Project>
